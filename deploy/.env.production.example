# ============================================================
# die kleine Börse — Produktions-Umgebungsvariablen
# Kopiere diese Datei nach /var/www/diekleineboerse/.env
# und fülle alle Werte aus. NIEMALS in Git committen!
# ============================================================

# Node.js
NODE_ENV=production
PORT=8080

# Session (min. 32 zufällige Zeichen — z.B. openssl rand -hex 32)
SESSION_SECRET=

# Datenbank (Neon, Supabase oder lokales PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Object Storage (Replit Object Storage oder S3-kompatibel)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=uploads/private
PUBLIC_OBJECT_SEARCH_PATHS=uploads/public

# Admin
ADMIN_EMAIL=welik.jakob@gmail.com

# Stripe (optional — für Premium-Anzeigen)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# Domain (ohne https://)
# DOMAIN=diekleineboerse.at
